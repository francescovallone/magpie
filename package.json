{
  "name": "@avesbox/magpie",
  "version": "0.1.5",
  "description": "Acceptance criteria scenarios on top of Vitest.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:acceptance": "vitest run --project acceptance",
    "test:unit": "vitest run --project unit",
    "test:watch": "vitest",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "keywords": [
    "acceptance-testing",
    "vitest",
    "testing",
    "traceability"
  ],
  "author": "Francesco Vallone",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0",
    "vitest": ">=4.0.0 < 5.0.0"
  },
  "peerDependencies": {
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0",
    "vitest": ">=4.0.0 < 5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "dependencies": {
    "@cucumber/cucumber-expressions": "^20.0.0",
    "@cucumber/gherkin": "^41.0.0",
    "@cucumber/messages": "^33.0.4"
  },
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/francescovallone/magpie.git"
  },
  "bugs": {
    "url": "https://github.com/francescovallone/magpie/issues"
  },
  "homepage": "https://github.com/francescovallone/magpie#readme"
}
